// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  role        String
  language    String
  name        String?
  socialHandle String?
  queuePosition Int
  createdAt   DateTime @default(now())
}
